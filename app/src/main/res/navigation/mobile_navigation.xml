<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_dashboard">

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.example.cybersuraksha.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_scanner"
        android:name="com.example.cybersuraksha.ScannerFragment"
        android:label="Scanner"
        tools:layout="@layout/fragment_scanner" />

    <fragment
        android:id="@+id/navigation_analyzer"
        android:name="com.example.cybersuraksha.AnalyzerFragment"
        android:label="Analyzer"
        tools:layout="@layout/fragment_analyzer" />

    <fragment
        android:id="@+id/navigation_web"
        android:name="com.example.cybersuraksha.WebProtectionFragment"
        android:label="Web"
        tools:layout="@layout/fragment_web_protection" />

    <fragment
        android:id="@+id/navigation_identity"
        android:name="com.example.cybersuraksha.IdentityToolsFragment"
        android:label="Identity"
        tools:layout="@layout/fragment_identity_tools" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.example.cybersuraksha.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />
</navigation>